<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <connectionStrings>
    <!--
      MySQL connection string.
      Change 'root' and 'password' to match your MySQL credentials.
      Default MySQL root password is whatever you set during installation.
      If installed via XAMPP, the default is: user=root, no password (leave password= blank).
    -->
    <add name="StudentDB"
         connectionString="Server=localhost;Port=3306;Database=student;Uid=root;Pwd=Update your password in here;"
         providerName="MySql.Data.MySqlClient" />
  </connectionStrings>
</configuration>
